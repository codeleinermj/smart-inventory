# =============================================================================
# Smart Inventory — environment variables
# =============================================================================
# IMPORTANT: copy this file to `.env` and replace placeholder values.
# `.env` is git-ignored. Never commit real secrets.
#
# To generate a strong JWT_SECRET (Linux/Mac/Git Bash):
#   openssl rand -base64 32
# Or in PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Max 256 }))
# =============================================================================

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- Postgres ---
# These values are read by docker-compose.yml. The container always uses port 5432
# internally; from the host the port is remapped to 5433 to avoid conflicts.
POSTGRES_USER=smart_inv
POSTGRES_PASSWORD=smart_inv
POSTGRES_DB=smart_inv

# --- Connection strings ---
# From the host (e.g. running `pnpm --filter api dev` natively): use port 5433.
# From inside Docker (api container reading this): the compose file overrides this.
DATABASE_URL=postgresql://smart_inv:smart_inv@localhost:5433/smart_inv
REDIS_URL=redis://localhost:6379
ML_SERVICE_URL=http://localhost:8000

# --- Auth (REQUIRED — must be set to a strong random value) ---
JWT_SECRET=replace-me-with-a-real-32-char-secret

# --- Observability (optional — leave empty to disable Sentry) ---
SENTRY_DSN=
