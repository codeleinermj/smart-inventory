# Node API
NODE_ENV=development
LOG_LEVEL=info
# From the host: postgres is on port 5433 (remapped to avoid conflicts with other projects).
# From inside Docker (api/ml containers): postgres is on port 5432.
DATABASE_URL=postgresql://smart_inv:smart_inv@localhost:5433/smart_inv
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-me-with-a-real-32-char-secret
ML_SERVICE_URL=http://localhost:8000

# Observability (optional — leave empty to disable)
SENTRY_DSN=
